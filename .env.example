# =====================================================================
# Configuração de ambiente — Monitoramento Multimodal de Pacientes
# Copie este arquivo para `.env` e preencha com suas credenciais.
# NUNCA faça commit do arquivo `.env` (já está no .gitignore).
# =====================================================================

# --- Azure Speech to Text (RF02) ---
# Portal Azure > Speech service > Keys and Endpoint
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=brazilsouth

# --- Azure Language / Text Analytics (RF02) ---
# Portal Azure > Language service > Keys and Endpoint
AZURE_LANGUAGE_KEY=
AZURE_LANGUAGE_ENDPOINT=

# --- Comportamento da aplicação ---
# Se as credenciais Azure estiverem ausentes, os módulos operam em modo
# "mock" (offline) para permitir demonstração local sem custo de nuvem.
APP_ENV=development
LOG_LEVEL=INFO

# Idioma padrão para transcrição/análise de áudio
DEFAULT_LOCALE=pt-BR

# --- Parâmetros de detecção de anomalias (RF03) ---
# Contaminação esperada (fração de anomalias) para o IsolationForest
ANOMALY_CONTAMINATION=0.02
# Limiar de z-score para regras estatísticas de sinais vitais
VITALS_ZSCORE_THRESHOLD=3.0

# --- Alertas ---
# Canal de destino dos alertas: console | file | webhook
ALERT_CHANNEL=console
# URL de webhook (ex.: Microsoft Teams / Slack) usada quando ALERT_CHANNEL=webhook
ALERT_WEBHOOK_URL=
