# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables & secrets
.env
.env.*
!.env.example
# Runbook local de deploy com chaves Azure em texto puro — NUNCA versionar
config.txt
secrets.txt
*.secrets

# Test / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# Model weights / large binaries (not versioned)
*.pt
*.onnx
*.h5
*.mp4
*.wav
*.mp3
!data/samples/**/*.wav
!data/samples/video_teste.mp4
# áudios da coorte: gerados por SAPI (Windows-only) via TTS — versionados
# para que graders em qualquer SO tenham o dataset completo e reprodutível.
!data/patients/**/*.wav
# vídeo por paciente NÃO é versionado (20 MB/arquivo, opt-in):
# copie data/samples/video_teste.mp4 para a pasta do paciente para ativar.

# Generated artifacts / outputs
outputs/
reports/
*.log

# Datasets sensíveis (NUNCA versionar dados reais de pacientes)
data/raw/
data/private/

# IDE
.idea/
.vscode/
*.swp
.DS_Store
