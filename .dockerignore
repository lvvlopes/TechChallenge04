# Contexto de build enxuto — mantém a imagem pequena e o upload rápido.
.git/
.venv/
venv/
env/
ENV/

__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Segredos nunca entram na imagem (vão como env vars no Container Apps).
.env
.env.*
!.env.example

# Dados e mídia de amostra não são necessários em runtime — exceto a coorte
# sintética, que a página /patients lê em runtime (ver COPY no Dockerfile).
data/*
!data/patients.json
!data/patients_media
notebooks/
tests/
docs/
*.pdf
*.mp4
*.mp3
*.pt
*.onnx

outputs/
reports/
*.log

.vscode/
.idea/
.DS_Store
